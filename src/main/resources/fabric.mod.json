{
	"schemaVersion": 1,
	"id": "custom-hotbar",
	"version": "${version}",
	"name": "Customizable Hotbar",
	"description": "Adds a configurable 3x3 hotbar to your game and other things",
	"authors": [
		"stenlan",
		"NBSgamesAT"
	],
	"contact": {
		"homepage": "https://github.com/NBSgamesAT/fabric-3x3hotbar",
		"sources": "https://github.com/NBSgamesAT/fabric-3x3hotbar/tree/nbs-custom-hotbar"
	},
	"license": "CC BY-NC-SA 4.0",
	"icon": "assets/customhotbar/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			"at.nbsgames.customhotbar.Hotbar3x3Client"
		],
		"modmenu": [
			"at.nbsgames.customhotbar.config.Hotbar3x3ModMenuIntegration"
		]
	},
	"mixins": [
		{
			"config": "3x3hotbar.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.5",
		"minecraft": ["~26.1.0"],
		"java": ">=25",
		"fabric-api": "*",
		"cloth-config": ["~26.1.154"],
		"modmenu": ["~18.0.0-alpha.8", "~18.0.0-beta.1", "~18.0.0"]
	}
}